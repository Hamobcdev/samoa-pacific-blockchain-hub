# Deployer wallet (used to broadcast all transactions)
ADMIN_ADDRESS=0xYourDeployerWalletAddress
PRIVATE_KEY=0xYourDeployerPrivateKey

# Per-ministry admin addresses (Step 2)
# Each ministry node gets its own dedicated admin key.
# Using the same address for multiple ministries defeats the purpose —
# a single compromised key would control multiple nodes.
ADMIN_CBS=0xCBSAdminAddress
ADMIN_MCIT=0xMCITAdminAddress
ADMIN_MOF=0xMOFAdminAddress
ADMIN_MCIL=0xMCILAdminAddress
ADMIN_EDUCATION=0xEducationAdminAddress
ADMIN_CUSTOMS=0xCustomsAdminAddress
ADMIN_SBS=0xSBSAdminAddress

# RPC endpoints
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_RPC_URL=https://polygon-rpc.com

# Block explorer verification
POLYGONSCAN_API_KEY=YourPolygonscanAPIKey

# Contract addresses (populated after Step 1 and Step 2)
NDIDS_ADDRESS=0x...
AID_ADDRESS=0x...
HUB_ADDRESS=0x...
CBS_ADDRESS=0x...
MCIT_ADDRESS=0x...
MOF_ADDRESS=0x...
MCIL_ADDRESS=0x...
EDUCATION_ADDRESS=0x...
CUSTOMS_ADDRESS=0x...
SBS_ADDRESS=0x...
