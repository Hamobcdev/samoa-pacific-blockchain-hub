# Samoa DPI RPC Proxy API — Environment Variables
# Copy to .env and set values. Never commit .env.

# ── RPC endpoint ─────────────────────────────────────────────────────────
# Leave blank for Phase 1 stub responses
RPC_ENDPOINT_URL=

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5181,http://localhost:5182

# ── Supabase (Phase 2 — audit persistence) ───────────────────────────────
# Leave blank for Phase 1 in-memory audit log
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
