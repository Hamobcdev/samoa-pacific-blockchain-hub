# Samoa DPI Admin Portal — Environment Variables
# Copy to .env and set values. Never commit .env.

# ── Feature flags — Phase 1: all false ──────────────────────────────────
# Set to 'true' to enable a phase-gated feature.
VITE_FLAG_MULTISIG_ACTIVE=false
VITE_FLAG_CBDC_BRIDGE_ACTIVE=false
VITE_FLAG_CROSS_MINISTRY_ACTIVE=false
VITE_FLAG_LIVE_RPC_ACTIVE=false
VITE_FLAG_COLD_WALLET=false
VITE_FLAG_USDC=false
VITE_FLAG_WST_LIVE=false
VITE_FLAG_SOVEREIGN_CHAIN=false
VITE_FLAG_CIRCUIT_BREAKER=false

# ── CBS Governance flags (matches CBS_GOVERNANCE_ITEMS featureFlag fields) ──
VITE_FLAG_MULTISIG=false
VITE_FLAG_CONSENT=false
VITE_FLAG_TIMELOCK=false
VITE_FLAG_VALIDATOR_GOV=false
VITE_FLAG_FATF=false

# ── Service layer ────────────────────────────────────────────────────────
# Set to 'true' to fetch live node health from RPC proxy (requires api/ running)
VITE_USE_LIVE_DATA=false

# ── Portal URLs (used for cross-portal navigation links) ─────────────────
VITE_URL_CITIZENS=http://localhost:5181
VITE_URL_ADMIN=http://localhost:5182
VITE_URL_DBS=http://localhost:5183
VITE_URL_DONOR=http://localhost:5184
VITE_URL_VERIFY=http://localhost:5185
